# ─────────────────────────────────────────────────────────────
# Kursly — environment variables (copy to .env and fill in)
# ─────────────────────────────────────────────────────────────

# ---- Postgres (used by docker-compose & Prisma) ----
POSTGRES_USER=kursly
POSTGRES_PASSWORD=kursly_dev_password
POSTGRES_DB=kursly
POSTGRES_PORT=5432

# ---- API (apps/api) ----
API_PORT=4000
NODE_ENV=development

# Prisma connection string. When running the API inside docker-compose,
# the host is the service name `postgres`; locally it is `localhost`.
DATABASE_URL=postgresql://kursly:kursly_dev_password@localhost:5432/kursly?schema=public

# JWT secrets — generate strong random values in production
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ---- Cloudflare R2 (S3-compatible video storage) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=kursly-videos
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=
R2_PRESIGN_EXPIRES_IN=3600

# ---- Web (apps/web) ----
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
